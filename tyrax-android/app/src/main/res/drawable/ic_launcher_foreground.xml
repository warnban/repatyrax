<?xml version="1.0" encoding="utf-8"?>
<!--
    TYRAX launcher mark: bold "T" letterform with a red glitch offset.
    Transparent background — the adaptive icon supplies the black backdrop.
    Drawn inside the 108dp viewport, kept within the ~66dp adaptive safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Red glitch echo, offset down-right, sits behind the white mark. -->
    <path
        android:fillColor="#FF1E1E"
        android:fillAlpha="0.9"
        android:pathData="M34,34 H82 V48 H65 V85 H51 V48 H34 Z" />

    <!-- Small detached glitch slice for digital-fracture feel. -->
    <path
        android:fillColor="#FF1E1E"
        android:fillAlpha="0.55"
        android:pathData="M30,60 H45 V66 H30 Z" />

    <!-- Main white "T". -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,30 H78 V44 H61 V82 H47 V44 H30 Z" />
</vector>
