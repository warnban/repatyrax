<UserControl x:Class="Tyrax.App.Views.NodesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource TyraxBlack}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="ЛОКАЦИИ" Style="{StaticResource TyraxHeadline}" FontSize="26" />
            <Button Content="ОБНОВИТЬ" Command="{Binding RefreshCommand}"
                    Style="{StaticResource TyraxGhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <ListBox Grid.Row="1" ItemsSource="{Binding Nodes}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.Resources>
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource TyraxScrollViewer}" />
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource TyraxListItem}" />
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource TyraxPanel}" BorderBrush="{StaticResource TyraxDim}"
                            BorderThickness="1" Padding="14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Codename}"
                                           Foreground="{StaticResource TyraxWhite}"
                                           FontFamily="{StaticResource TyraxFont}"
                                           FontWeight="Black" FontSize="18" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBrush}"
                                               FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11" />
                                    <TextBlock Text="{Binding LoadText}" Foreground="{StaticResource TyraxDim}"
                                               FontFamily="{StaticResource TyraxFont}" FontWeight="Bold"
                                               FontSize="11" Margin="12,0,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding PingText}"
                                       VerticalAlignment="Center" Margin="0,0,14,0"
                                       Foreground="{StaticResource TyraxWhite}"
                                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="13" />

                            <Button Grid.Column="2" Content="ВОЙТИ"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding IsSelectable}"
                                    Command="{Binding DataContext.ChooseCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource TyraxGhostButton}"
                                    FontWeight="Black" FontSize="12"
                                    BorderBrush="{StaticResource TyraxWhite}" BorderThickness="1"
                                    Foreground="{StaticResource TyraxWhite}" Padding="14,6" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="{Binding Error}" Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="260"
                       Visibility="{Binding Error, Converter={StaticResource NonEmptyToVis}}" />
            <Button Command="{Binding BackCommand}" Style="{StaticResource TyraxBackButton}" />
        </Grid>
    </Grid>
</UserControl>
