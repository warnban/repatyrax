<UserControl x:Class="Tyrax.App.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource TyraxBlack}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,4">
            <TextBlock Text="УСТРОЙСТВА" Style="{StaticResource TyraxHeadline}" FontSize="26" />
            <Button Content="ОБНОВИТЬ" Command="{Binding RefreshCommand}"
                    Style="{StaticResource TyraxGhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>
        <TextBlock Grid.Row="0" Text="{Binding CountLine}" VerticalAlignment="Bottom"
                   Style="{StaticResource TyraxLabel}" FontSize="11" Margin="0,0,0,10" />

        <ListBox Grid.Row="1" ItemsSource="{Binding Devices}"
                 Background="Transparent" BorderThickness="0"
                 HorizontalContentAlignment="Stretch">
            <ListBox.Resources>
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource TyraxScrollViewer}" />
            </ListBox.Resources>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource TyraxListItem}" />
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource TyraxPanel}" BorderThickness="1" Padding="14,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource TyraxDim}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource TyraxRed}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TyraxWhite}"
                                           FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="16" />
                                <TextBlock Text="{Binding Meta}" Foreground="{StaticResource TyraxDim}"
                                           FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="10"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding Meta, Converter={StaticResource NonEmptyToVis}}" />
                            </StackPanel>

                            <Button Grid.Column="1" Content="ОТВЯЗАТЬ" VerticalAlignment="Center"
                                    Command="{Binding RevokeCommand}"
                                    Visibility="{Binding CanRevoke, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource TyraxGhostButton}"
                                    Foreground="{StaticResource TyraxRed}" FontSize="12" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="{Binding Error}" Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="260"
                       Visibility="{Binding Error, Converter={StaticResource NonEmptyToVis}}" />
            <Button Command="{Binding BackCommand}" Style="{StaticResource TyraxBackButton}" />
        </Grid>
    </Grid>
</UserControl>
