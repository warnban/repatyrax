<UserControl x:Class="Tyrax.App.Views.SubscriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource TyraxBlack}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="ТАРИФЫ" Style="{StaticResource TyraxHeadline}" FontSize="26" />
            <TextBlock Text="{Binding StatusLine}" Style="{StaticResource TyraxLabel}" FontSize="11"
                       Margin="0,6,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Style="{StaticResource TyraxScrollViewer}">
            <StackPanel>
                <!-- Блок расхода трафика -->
                <Border BorderThickness="1" Padding="16" Margin="0,0,0,14"
                        Visibility="{Binding ShowUsage, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource TyraxDim}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowBlocked}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource TyraxRed}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="{Binding UsageTitle}" Foreground="{StaticResource TyraxWhite}"
                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="14" />
                        <TextBlock Text="{Binding UsageDetail}" Foreground="{StaticResource TyraxDim}"
                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11"
                                   Margin="0,8,0,0" TextWrapping="Wrap" />
                        <Border Height="4" Background="#FF1A1A1A" Margin="0,12,0,0"
                                Visibility="{Binding IsUnlimited, Converter={StaticResource InverseBoolToVis}}">
                            <Border HorizontalAlignment="Left" Background="{StaticResource TyraxRed}"
                                    Width="{Binding UsagePercent, Converter={StaticResource UsageBarWidth}}" />
                        </Border>
                        <TextBlock Text="{Binding BlockedLine}" Foreground="{StaticResource TyraxRed}"
                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11"
                                   Margin="0,10,0,0" TextWrapping="Wrap"
                                   Visibility="{Binding ShowBlocked, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Tiers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" Padding="16" Margin="0,0,0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource TyraxWhite}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource TyraxRed}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="20">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TyraxWhite}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TyraxRed}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Features}" Style="{StaticResource TyraxLabel}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding PriceText}" Foreground="{StaticResource TyraxWhite}"
                                               FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="13"
                                               Margin="0,12,0,0" />

                                    <Border Margin="0,14,0,0" BorderBrush="{StaticResource TyraxRed}" BorderThickness="1"
                                            Padding="0,10" Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="ТЕКУЩИЙ ТАРИФ" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TyraxRed}"
                                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12" />
                                    </Border>

                                    <Button Content="РАЗБЛОКИРОВАТЬ" Command="{Binding UnlockCommand}"
                                            Style="{StaticResource TyraxButton}" Margin="0,14,0,0" FontSize="16"
                                            Visibility="{Binding CanUnlock, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,8,0,0" Visibility="{Binding IsDominion, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="СУБ-АККАУНТЫ" Style="{StaticResource TyraxLabel}" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewInviteId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource TyraxTextBox}" />
                        <Button Grid.Column="1" Content="ПРИГЛАСИТЬ" Command="{Binding SendInviteCommand}"
                                Margin="8,0,0,0" Style="{StaticResource TyraxGhostButton}"
                                BorderBrush="{StaticResource TyraxWhite}" BorderThickness="1"
                                Foreground="{StaticResource TyraxWhite}" Padding="16,8" />
                    </Grid>
                    <TextBlock Text="{Binding InviteError}" Foreground="{StaticResource TyraxRed}"
                               FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11"
                               Margin="0,8,0,0"
                               Visibility="{Binding InviteError, Converter={StaticResource NonEmptyToVis}}" />

                    <ItemsControl ItemsSource="{Binding Invites}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource TyraxPanel}" BorderBrush="{StaticResource TyraxDim}"
                                        BorderThickness="1" Padding="12,10" Margin="0,0,0,8">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding InviteeId}" Foreground="{StaticResource TyraxWhite}"
                                                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12" />
                                            <TextBlock Text="{Binding Status}" Foreground="{StaticResource TyraxDim}"
                                                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold"
                                                       FontSize="10" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Button Content="ОТОЗВАТЬ" Command="{Binding RemoveCommand}"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Style="{StaticResource TyraxGhostButton}"
                                                Foreground="{StaticResource TyraxRed}" FontSize="11" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="{Binding Error}" Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="260"
                       Visibility="{Binding Error, Converter={StaticResource NonEmptyToVis}}" />
            <Button Command="{Binding BackCommand}" Style="{StaticResource TyraxBackButton}" />
        </Grid>
    </Grid>
</UserControl>
