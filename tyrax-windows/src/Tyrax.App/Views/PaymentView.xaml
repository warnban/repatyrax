<UserControl x:Class="Tyrax.App.Views.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource TyraxBlack}">

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="РАЗБЛОКИРОВКА" Style="{StaticResource TyraxHeadline}" FontSize="26" />
            <TextBlock Text="{Binding Tier}" Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="14"
                       Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Style="{StaticResource TyraxScrollViewer}">
            <StackPanel>
                <TextBlock Text="СРОК" Style="{StaticResource TyraxLabel}" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding MonthOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Label}" Style="{StaticResource TyraxChipButton}"
                                    Command="{Binding DataContext.ChooseMonthsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="СПОСОБ" Style="{StaticResource TyraxLabel}" Margin="0,10,0,10" />
                <ItemsControl ItemsSource="{Binding MethodOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Label}" Style="{StaticResource TyraxChipButton}"
                                    Command="{Binding DataContext.ChooseMethodCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border BorderBrush="{StaticResource TyraxDim}" BorderThickness="1" Padding="16" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalText}" Foreground="{StaticResource TyraxWhite}"
                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="22" />
                        <TextBlock Text="{Binding MonthlyText}" Style="{StaticResource TyraxLabel}" FontSize="12" Margin="0,6,0,0" />
                        <TextBlock Text="{Binding SavingText}" Foreground="{StaticResource TyraxRed}"
                                   FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding SavingText, Converter={StaticResource NonEmptyToVis}}" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TyraxWhite}"
                           FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="13"
                           Margin="0,14,0,0"
                           Visibility="{Binding StatusText, Converter={StaticResource NonEmptyToVis}}" />
                <TextBlock Text="{Binding Error}" Foreground="{StaticResource TyraxRed}"
                           FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                           Margin="0,10,0,0" TextWrapping="Wrap"
                           Visibility="{Binding Error, Converter={StaticResource NonEmptyToVis}}" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <StackPanel>
                <Button Content="ОПЛАТИТЬ" Style="{StaticResource TyraxButton}"
                        Command="{Binding PayCommand}" IsEnabled="{Binding Busy, Converter={StaticResource NotBool}}" />
            </StackPanel>
            <Button Command="{Binding BackCommand}" Style="{StaticResource TyraxBackButton}" VerticalAlignment="Bottom" />
        </Grid>
    </Grid>
</UserControl>
