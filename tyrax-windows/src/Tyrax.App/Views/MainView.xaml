<UserControl x:Class="Tyrax.App.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:comp="clr-namespace:Tyrax.App.Components"
             mc:Ignorable="d"
             Background="{StaticResource TyraxBlack}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Цифровой дождь при активном туннеле -->
        <comp:DigitalRainView Grid.Row="0" IsActive="{Binding IsRainActive}" />

        <!-- Баннер обновления -->
        <Button Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                Content="{Binding UpdateText}" Command="{Binding OpenUpdateCommand}"
                Visibility="{Binding UpdateText, Converter={StaticResource NonEmptyToVis}}"
                Background="{StaticResource TyraxRed}" Foreground="{StaticResource TyraxWhite}"
                BorderThickness="0" Cursor="Hand" Padding="0,8"
                FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11" />

        <!-- Баннер исчерпанной квоты -->
        <Button Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,0,0,0"
                Command="{Binding OpenTariffsFromBannerCommand}"
                Visibility="{Binding ShowBlockedBanner, Converter={StaticResource BoolToVis}}"
                Background="#FF1A0000" BorderBrush="{StaticResource TyraxRed}" BorderThickness="0,0,0,2"
                Cursor="Hand" Padding="12,10">
            <StackPanel>
                <TextBlock Text="{Binding BlockedText}" Foreground="{StaticResource TyraxRed}"
                           FontFamily="{StaticResource TyraxFont}" FontWeight="Black" FontSize="12"
                           HorizontalAlignment="Center" />
                <TextBlock Text="РАЗБЛОКИРОВАТЬ В ТАРИФАХ →" Foreground="{StaticResource TyraxDim}"
                           FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="10"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Button>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="30" TextAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="360">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource TyraxHeadline}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBreaching}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="GlitchStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity" Duration="0:0:0.5">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.08" Value="0.25" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.12" Value="1.0" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.28" Value="0.6" />
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.32" Value="1.0" />
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="GlitchStoryboard" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <TextBlock Text="{Binding NodeTag}"
                       Style="{StaticResource TyraxLabel}"
                       Margin="0,18,0,0" HorizontalAlignment="Center" />

            <!-- Прогрев канала: xray поднимает VLESS+Reality при первом трафике (~30-60 сек) -->
            <TextBlock Text="{Binding WarmUpText}"
                       Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="11"
                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="340"
                       Margin="0,14,0,0" HorizontalAlignment="Center"
                       Visibility="{Binding ShowWarmUp, Converter={StaticResource BoolToVis}}" />

            <TextBlock Text="{Binding QuotaText}"
                       Foreground="{StaticResource TyraxRed}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                       Margin="0,10,0,0" HorizontalAlignment="Center"
                       Visibility="{Binding ShowQuota, Converter={StaticResource BoolToVis}}" />

            <TextBlock Text="{Binding TrafficText}"
                       Foreground="{StaticResource TyraxDim}"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="12"
                       Margin="0,8,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,28" HorizontalAlignment="Center">
            <TextBlock Text="{Binding ServiceStatusText}" HorizontalAlignment="Center" Margin="0,0,0,14"
                       FontFamily="{StaticResource TyraxFont}" FontWeight="Bold" FontSize="10">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource TyraxRed}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ServiceOnline}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TyraxDim}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button Content="{Binding ActionText}"
                    Style="{StaticResource TyraxButton}"
                    Command="{Binding ToggleCommand}"
                    MinWidth="260" />

            <UniformGrid Columns="4" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="ЛОКАЦИИ" Command="{Binding OpenNodesCommand}" Style="{StaticResource TyraxGhostButton}" Margin="4,0" />
                <Button Content="УСТРОЙСТВА" Command="{Binding OpenDevicesCommand}" Style="{StaticResource TyraxGhostButton}" Margin="4,0" />
                <Button Content="ТАРИФЫ" Command="{Binding OpenControlCommand}" Style="{StaticResource TyraxGhostButton}" Margin="4,0" />
                <Button Content="НАСТРОЙКИ" Command="{Binding OpenSettingsCommand}" Style="{StaticResource TyraxGhostButton}" Margin="4,0" />
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
