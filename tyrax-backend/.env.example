# TYRAX Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Fiber server listens on inside the container.
PORT=8080
# JWT signing secret — MUST be a long random string in production (64+ chars).
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# pgx connection string. In docker-compose the host is the "postgres" service.
DATABASE_URL=postgres://tyrax:tyrax@localhost:5432/tyrax?sslmode=disable
# Password injected into the postgres container + DATABASE_URL (compose only).
POSTGRES_PASSWORD=tyrax_dev

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather. Required for the Telegram deep-link auth flow.
TELEGRAM_BOT_TOKEN=
# Public bot URL returned to the client for the "ENTER VIA TELEGRAM" flow.
TELEGRAM_BOT_URL=https://t.me/tyraxvpnbot
# Bot @username (without @) returned by /auth/telegram-init for the deep link.
TELEGRAM_BOT_USERNAME=tyraxvpnbot
# Support contact shown in the bot + used as the payer email fallback for invoices.
SUPPORT_EMAIL=support@tyrax.app

# ── FreeKassa (API-only, not SCI form) ───────────────────────────────────────
# Register at https://merchant.freekassa.net
# Enable methods i=44 (СБП) and i=36 (Карты РФ) in shop settings.
FREEKASSA_SHOP_ID=
FREEKASSA_API_KEY=
# "Secret word 2" — used to verify incoming webhook signatures.
FREEKASSA_SECRET_WORD_2=

# ── CryptoPay (via @CryptoBot) ───────────────────────────────────────────────
# Get token: @CryptoBot → Crypto Pay → Create App
# Enable webhooks: @CryptoBot → Crypto Pay → My Apps → Webhooks
CRYPTO_PAY_TOKEN=
