# TYRAX Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Fiber server listens on inside the container.
PORT=8080
# JWT signing secret — MUST be a long random string in production (64+ chars).
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────────────────────
# pgx connection string. In docker-compose the host is the "postgres" service.
DATABASE_URL=postgres://tyrax:tyrax@localhost:5432/tyrax?sslmode=disable
# Password injected into the postgres container + DATABASE_URL (compose only).
POSTGRES_PASSWORD=tyrax_dev

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Bot token from @BotFather. Required for the Telegram deep-link auth flow.
TELEGRAM_BOT_TOKEN=
# Proxy for reaching api.telegram.org. REQUIRED when the backend runs on a Russian
# host (Telegram API is blocked by RKN there). Point it at a proxy on a foreign
# node. Supports http:// (e.g. tinyproxy) and socks5:// (e.g. an Xray socks inbound).
# Example: TELEGRAM_PROXY=http://195.26.230.238:8888
TELEGRAM_PROXY=
# Public bot URL returned to the client for the "ENTER VIA TELEGRAM" flow.
TELEGRAM_BOT_URL=https://t.me/tyraxvpnbot
# Bot @username (without @) returned by /auth/telegram-init for the deep link.
TELEGRAM_BOT_USERNAME=tyraxvpnbot
# Support contact shown in the bot + used as the payer email fallback for invoices.
SUPPORT_EMAIL=support@tyrax.tech
# Public site — bot download buttons point here (/download/tyrax.apk, /download/windows/TYRAX-Setup.exe).
WEBSITE_URL=https://tyrax.tech
# Public API base — Happ subscription URLs: {PUBLIC_API_URL}/sub/{token}
PUBLIC_API_URL=https://api.tyrax.tech
# Windows installer semver — drives GET /download/windows/latest.json
WINDOWS_APP_VERSION=1.0.11

# ── FreeKassa (API-only, not SCI form) ───────────────────────────────────────
# Register at https://merchant.freekassa.net
# Enable methods i=44 (СБП) and i=36 (Карты РФ) in shop settings.
FREEKASSA_SHOP_ID=
FREEKASSA_API_KEY=
# "Secret word 2" — used to verify incoming webhook signatures.
FREEKASSA_SECRET_WORD_2=

# ── CryptoPay (via @CryptoBot) ───────────────────────────────────────────────
# Get token: @CryptoBot → Crypto Pay → Create App
# Enable webhooks: @CryptoBot → Crypto Pay → My Apps → Webhooks
CRYPTO_PAY_TOKEN=

# ── Admin panel (admin.tyrax.tech) ───────────────────────────────────────────
# Option A (simplest): plain password — no $ escaping issues in Docker .env
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Option B: bcrypt hash — escape every $ as $$ in .env, OR use base64 form below
# Generate: go run ./cmd/hashpass/main.go "your-password"
ADMIN_PASSWORD_HASH=
# Option C: base64 of bcrypt hash (safe for Docker .env, no $$ needed)
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes('$2a$12$...'))
ADMIN_PASSWORD_HASH_B64=

# Separate secret for admin JWT (defaults to JWT_SECRET if unset).
# Generate: -join ((1..32 | ForEach-Object { '{0:x2}' -f (Get-Random -Maximum 256) }))
ADMIN_JWT_SECRET=

# ── Support bot (@tyrax_support_bot) ─────────────────────────────────────────
TELEGRAM_SUPPORT_BOT_TOKEN=
TELEGRAM_SUPPORT_BOT_URL=https://t.me/tyrax_support_bot
